# Claude bot credentials — sourced by cron scripts and watchdog
#
# Setup:
#   1. Copy this to ~/.claude/bot-credentials.env
#   2. Fill in your real values
#   3. chmod 600 ~/.claude/bot-credentials.env
#
# Usage in scripts:
#   source "$HOME/.claude/bot-credentials.env"
#   BOT_TOKEN="$BOT_TOKEN_1"
#   CHAT_ID="$TELEGRAM_CHAT_ID"

BOT_TOKEN_1="<your-first-bot-token-from-botfather>"
BOT_TOKEN_2="<your-second-bot-token-from-botfather>"
TELEGRAM_CHAT_ID="<your-telegram-user-id>"

# Add any other secrets your cron scripts need:
# SOME_API_KEY="<your-api-key>"
