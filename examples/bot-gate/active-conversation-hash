#!/usr/bin/env python3
"""
active-conversation-hash — L1 helper for the bot gate.
Given a bot state file, extract the `## Active Conversation` section,
canonicalize it, and emit a stable SHA-1 hash.

Exit codes (hard contract — the gate branches on these):
  0  success. Stdout = 40-char lowercase hex sha1.
  1  helper internal bug (unexpected exception, I/O error on read).
     Gate should fail-open + sentinel.
  2  AC section missing / malformed / empty / duplicated. Gate
     should fail-closed (explicit repair message to the bot).

Canonicalization rules:
  - CRLF normalized to LF.
  - Only exact `## Active Conversation` at level 2 counts. Setext
    headers (underlined) and wrong-level (`#`, `###`, etc.) are
    ignored for section detection.
  - Duplicate `## Active Conversation` headers → exit 2 (malformed).
  - Fenced code blocks (```...```) are removed before hashing (their
    content is ignored for hash purposes).
  - Single-line HTML comments <!-- ... --> are stripped.
  - Leading/trailing blank lines dropped.
  - Empty body after canonicalization → exit 2.
  - The hash is over the canonical body only, not the header.

Usage:
  active-conversation-hash <state-file>
  active-conversation-hash <state-file> --section "Active Conversation"
  active-conversation-hash --self-test   # run embedded fixture tests

  --raw      print the canonicalized body to stdout instead of the hash
             (debugging aid; still exits with the same codes)
"""
from __future__ import annotations

import argparse
import hashlib
import re
import sys
from typing import Tuple


# --- public API ---------------------------------------------------

DEFAULT_SECTION = "Active Conversation"


class MalformedSection(Exception):
    """Raised on parse errors that should map to exit 2."""


def canonicalize_section(text: str, section: str = DEFAULT_SECTION) -> str:
    """
    Extract and canonicalize the named ## section from `text`.
    Raises MalformedSection on any parse error the caller should
    surface as exit 2.
    """
    if text is None:
        raise MalformedSection("null input")

    # Rule 1: CRLF → LF. Also strip BOM if present.
    if text.startswith("\ufeff"):
        text = text.lstrip("\ufeff")
    text = text.replace("\r\n", "\n").replace("\r", "\n")

    # Rule 2: strip fenced code blocks BEFORE computing the section
    # boundary. Otherwise a `## foo` line inside a code fence
    # terminates the AC section early.
    text = re.sub(
        r"^```.*?^```",
        lambda m: "\n" * (m.group(0).count("\n")),
        text,
        flags=re.MULTILINE | re.DOTALL,
    )

    # Find the target header and the next level-2 header (or EOF).
    target_re = re.compile(
        r"^##[ \t]+" + re.escape(section) + r"[ \t]*$",
        re.MULTILINE,
    )
    matches = list(target_re.finditer(text))
    if not matches:
        raise MalformedSection(f"section '## {section}' not found")
    if len(matches) > 1:
        raise MalformedSection(
            f"duplicate '## {section}' header ({len(matches)} matches)"
        )

    start = matches[0].end()
    next_h2 = re.search(r"(?m)^##[ \t]+\S", text[start:])
    end = start + next_h2.start() if next_h2 else len(text)

    body = text[start:end]

    # Rule: strip single-line HTML comments.
    body = re.sub(r"<!--.*?-->", "", body)

    # Rule: drop leading/trailing blank lines, but preserve interior
    # blank lines (they're semantically meaningful inside markdown).
    lines = body.split("\n")
    while lines and lines[0].strip() == "":
        lines.pop(0)
    while lines and lines[-1].strip() == "":
        lines.pop()
    body = "\n".join(lines)

    # Rule: empty after canonicalization = malformed.
    if not body.strip():
        raise MalformedSection(f"section '## {section}' is empty")

    return body


def hash_section(text: str, section: str = DEFAULT_SECTION) -> str:
    body = canonicalize_section(text, section)
    return hashlib.sha1(body.encode("utf-8")).hexdigest()


# --- CLI ----------------------------------------------------------


def _main_file(path: str, section: str, raw: bool) -> int:
    try:
        with open(path, "r", encoding="utf-8", errors="replace") as fh:
            text = fh.read()
    except OSError as e:
        print(f"active-conversation-hash: cannot read {path}: {e}", file=sys.stderr)
        return 1

    try:
        body = canonicalize_section(text, section)
    except MalformedSection as e:
        print(f"active-conversation-hash: malformed: {e}", file=sys.stderr)
        return 2
    except Exception as e:  # noqa: BLE001
        print(f"active-conversation-hash: internal error: {e}", file=sys.stderr)
        return 1

    if raw:
        sys.stdout.write(body)
        if not body.endswith("\n"):
            sys.stdout.write("\n")
    else:
        print(hashlib.sha1(body.encode("utf-8")).hexdigest())
    return 0


def _self_test() -> int:
    """Minimal embedded smoke test."""
    cases: list[Tuple[str, str, int]] = [
        # (label, input, expected_rc)
        ("happy-path",
         "# Bot\n\n## Active Conversation\nhello\n\n## Next\nstuff\n", 0),
        ("missing", "# Bot\n\n## Next\nstuff\n", 2),
        ("empty",   "# Bot\n\n## Active Conversation\n\n## Next\n", 2),
        ("dup",     "## Active Conversation\na\n## Active Conversation\nb\n", 2),
        ("crlf",    "## Active Conversation\r\nhello\r\n", 0),
        ("fenced",  "## Active Conversation\n```\ncode\n```\ntext\n", 0),
        ("comment", "## Active Conversation\n<!-- hi -->text\n", 0),
        ("wrong-level-header",
         "# Bot\n\n# Active Conversation\nhello\n", 2),
        ("setext", "# Bot\n\nActive Conversation\n===================\nhello\n", 2),
    ]
    failed = 0
    for label, text, want in cases:
        try:
            canonicalize_section(text)
            rc = 0
        except MalformedSection:
            rc = 2
        except Exception:
            rc = 1
        ok = rc == want
        if not ok:
            failed += 1
            print(f"FAIL {label}: want rc={want}, got {rc}", file=sys.stderr)
        else:
            print(f"ok   {label}")
    if failed:
        print(f"{failed} failures", file=sys.stderr)
        return 1
    print("all self-tests passed")
    return 0


def main() -> int:
    ap = argparse.ArgumentParser(
        prog="active-conversation-hash",
        description="Hash the ## Active Conversation section of a bot state file.",
    )
    ap.add_argument("path", nargs="?", help="bot state file")
    ap.add_argument("--section", default=DEFAULT_SECTION)
    ap.add_argument("--raw", action="store_true",
                    help="print canonicalized body instead of hash")
    ap.add_argument("--self-test", action="store_true",
                    help="run embedded smoke tests")
    args = ap.parse_args()

    if args.self_test:
        return _self_test()
    if not args.path:
        ap.print_usage(sys.stderr)
        return 2
    return _main_file(args.path, args.section, args.raw)


if __name__ == "__main__":
    sys.exit(main())
