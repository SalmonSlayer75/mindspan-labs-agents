#!/usr/bin/env bash
#
# claude-bot - manage Claude Code Telegram bot daemons
#
# Usage:
#   claude-bot start   work|personal|all
#   claude-bot stop    work|personal|all
#   claude-bot status  [work|personal|all]
#   claude-bot logs    work|personal
#   claude-bot restart work|personal|all
#
# CUSTOMIZE: Update the BOT_* arrays below with your bot names.

set -euo pipefail

declare -A BOT_TMUX BOT_SOCKET BOT_SCRIPT

BOT_TMUX[work]="claude-work-bot"
BOT_SOCKET[work]="claude-work"
BOT_SCRIPT[work]="$HOME/bin/claude-work-bot-start.sh"

BOT_TMUX[personal]="claude-personal-bot"
BOT_SOCKET[personal]="claude-personal"
BOT_SCRIPT[personal]="$HOME/bin/claude-personal-bot-start.sh"

start_bot() {
    local name="$1"
    local session="${BOT_TMUX[$name]}"
    local socket="${BOT_SOCKET[$name]}"
    local script="${BOT_SCRIPT[$name]}"

    if tmux -L "$socket" has-session -t "$session" 2>/dev/null; then
        echo "$name bot already running"
        return 0
    fi

    tmux -L "$socket" new-session -d -s "$session" "$script"
    echo "$name bot started"
}

stop_bot() {
    local name="$1"
    local session="${BOT_TMUX[$name]}"
    local socket="${BOT_SOCKET[$name]}"

    if ! tmux -L "$socket" has-session -t "$session" 2>/dev/null; then
        echo "$name bot not running"
        return 0
    fi

    # Send Ctrl+C first for graceful shutdown, then kill the session
    tmux -L "$socket" send-keys -t "$session" C-c
    sleep 2
    tmux -L "$socket" kill-session -t "$session" 2>/dev/null || true
    echo "$name bot stopped"
}

status_bot() {
    local name="$1"
    local session="${BOT_TMUX[$name]}"
    local socket="${BOT_SOCKET[$name]}"

    if tmux -L "$socket" has-session -t "$session" 2>/dev/null; then
        echo "$name bot: RUNNING"
    else
        echo "$name bot: STOPPED"
    fi
}

logs_bot() {
    local name="$1"
    local session="${BOT_TMUX[$name]}"
    local socket="${BOT_SOCKET[$name]}"

    if ! tmux -L "$socket" has-session -t "$session" 2>/dev/null; then
        echo "$name bot not running"
        return 1
    fi

    echo "Attaching to $name bot. Press Ctrl+B then D to detach."
    tmux -L "$socket" attach-session -t "$session"
}

resolve_targets() {
    local target="${1:-all}"
    case "$target" in
        all) echo "work personal" ;;
        work|personal) echo "$target" ;;
        *) echo "Unknown bot: $target" >&2; exit 1 ;;
    esac
}

ACTION="${1:-status}"
TARGET="${2:-all}"

case "$ACTION" in
    start)   for bot in $(resolve_targets "$TARGET"); do start_bot "$bot"; done ;;
    stop)    for bot in $(resolve_targets "$TARGET"); do stop_bot "$bot"; done ;;
    restart) for bot in $(resolve_targets "$TARGET"); do stop_bot "$bot"; sleep 1; start_bot "$bot"; done ;;
    status)  for bot in $(resolve_targets "$TARGET"); do status_bot "$bot"; done ;;
    logs)
        [[ "$TARGET" == "all" ]] && { echo "Specify which bot: work or personal"; exit 1; }
        logs_bot "$TARGET" ;;
    *) echo "Usage: claude-bot {start|stop|restart|status|logs} {work|personal|all}"; exit 1 ;;
esac
